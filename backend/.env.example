# Backend Environment Variables Example
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Database Configuration
CONNECTION_STRING=mongodb://localhost:27017
DB_NAME=your_database_name

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=your_super_secret_jwt_access_token_key_here
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=your_super_secret_jwt_refresh_token_key_here
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# Security Configuration
OTP_EXPIRES_IN=10m
PASSWORD_RESET_EXPIRES_IN=5m
ACCOUNT_LOCK_DURATION=2h

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_SERVICE=gmail
SMTP_PORT=465
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Cloudflare R2 Configuration (for file uploads)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=gha-images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Bunny Stream Configuration (for video uploads)
BUNNY_LIBRARY_ID=your_bunny_library_id
BUNNY_API_KEY=your_bunny_api_key
BUNNY_STREAM_SECRET=your_bunny_stream_secret
BUNNY_CDN_HOST=vz-your_library_id.b-cdn.net

# Payment Configuration (optional)
PAYMENT_SECRET_KEY=your_payment_secret_key